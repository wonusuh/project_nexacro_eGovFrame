<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Sample_Script" width="1020" height="630" titletext="Sample_Script" onload="Form_onload">
    <Layouts>
      <Layout height="630" mobileorientation="landscape" width="1020">
