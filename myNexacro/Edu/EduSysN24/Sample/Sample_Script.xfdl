                <Cell col="4" text="직급"/>
                <Cell col="5" text="상태"/>
              </Band>
              <Band id="body">
                <Cell displaytype="checkboxcontrol" edittype="checkbox" text="bind:CHK"/>
                <Cell col="1" text="bind:DEPT_NAME"/>
                <Cell col="2" text="bind:EMP_NAME"/>
                <Cell col="3" text="bind:EMP_ID"/>
                <Cell col="4" text="bind:POSITION" displaytype="combotext" combodataset="ds_pos" combocodecol="CODE" combodatacol="CODE_NAME"/>
                <Cell col="5" text="bind:STATUS" combodataset="ds_status" combocodecol="CODE" combodatacol="CODE_NAME" displaytype="combotext"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btn_save" taborder="13" text="저장" top="10" width="60" height="26" right="10" visible="true" onclick="btn_save_onclick" cssclass="btn_WF_FillTeal"/>
