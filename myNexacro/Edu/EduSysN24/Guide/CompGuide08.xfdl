          <Layouts>
            <Layout>
              <Static id="Static00" taborder="0" text="[enabled]" left="20" top="10" width="160" height="30" cssclass="sta_WF_GStatus"/>
              <Menu id="Menu00" taborder="1" left="20" top="Static00:10" width="685" height="36" innerdataset="ds_mnu" captioncolumn="caption" checkboxcolumn="check" idcolumn="id" levelcolumn="level" hotkeycolumn="hotkey" iconcolumn="icon"/>
            </Layout>
          </Layouts>
        </Div>
