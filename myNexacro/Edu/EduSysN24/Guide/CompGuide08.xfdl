<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="CompGuide01" width="1020" height="890" titletext="mnu,pmnu,fdl,ful" ontimer="Form_ontimer">
    <Layouts>
      <Layout height="890" width="1020">
        <Static id="Static00" taborder="1" text="Component Guide" left="20" top="0" width="160" height="50" cssclass="sta_WF_GuideTitle1"/>
        <Static id="Static01" taborder="3" text="Menu" left="20" top="50" width="97" height="35" cssclass="sta_WF_GuideTitle2"/>
