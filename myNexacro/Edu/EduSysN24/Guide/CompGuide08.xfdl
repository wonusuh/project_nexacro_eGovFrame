              <PopupMenu id="pmnu" left="179" top="25" width="110" height="130" innerdataset="ds_mnu" captioncolumn="caption" checkboxcolumn="check" hotkeycolumn="hotkey" iconcolumn="icon" idcolumn="id" levelcolumn="level" enablecolumn="enable"/>
              <Button id="btnShow" taborder="1" text="PopupMenu" left="20" top="Static00:10" width="120" height="26" onclick="btnShow_onclick"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="Static03" taborder="5" text="FileUpload" left="20" top="Div01:20" width="97" height="35" cssclass="sta_WF_GuideTitle2"/>
