    <Script type="xscript5.1"><![CDATA[
this.Grid00_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	trace(e.col + "===" + e.cell);
	if(e.col == 0)
	{
		trace(obj.getCellProperty("body",e.col, "text"));
	}

};

this.Grid01_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var sText = this.Grid01.getCellProperty("body",e.col,"text");
	var arrCol = sText.split(":");
	var sColId = arrCol[1];	
 
	if(sColId == "EMPL_ID")
	{
		trace(obj.getCellProperty("body",e.col, "text"));
	}
};

this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.Grid00.cellmovingtype = "col";
	this.Grid01.cellmovingtype = "col";
};
]]></Script>
  </Form>
</FDL>
