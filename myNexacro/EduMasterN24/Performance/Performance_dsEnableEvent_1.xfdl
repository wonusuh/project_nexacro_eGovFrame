  <Form id="dsEnableEvent" width="1000" height="700" titletext="dsEnableEvent" onload="dsEnableEvent_onload">
    <Layouts>
      <Layout height="700" width="1000">
        <Div id="divLayOut" taborder="0" text="Div00" left="10" top="50" height="640" right="10" border="1px solid darkgray">
          <Layouts>
            <Layout>
              <Grid id="Grid00" taborder="0" left="0" top="0" height="289" binddataset="Dataset00" fastvscrolltype="centerdisplay" right="0" autofittype="col">
                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="48" band="left"/>
                      <Column size="228" band="left"/>
                      <Column size="448"/>
                    </Columns>
                    <Rows>
                      <Row size="24" band="head"/>
                      <Row size="24"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="no"/>
                      <Cell col="1" text="PlaceName"/>
                      <Cell col="2" text="Website"/>
                    </Band>
                    <Band id="body">
                      <Cell text="expr:currow + 1" textAlign="center"/>
                      <Cell col="1" text="bind:PlaceName"/>
                      <Cell col="2" text="bind:Website"/>
                    </Band>
                  </Format>
                </Formats>
              </Grid>
              <Static id="Static01" taborder="1" text="Time(Seconds)" left="10" top="307" width="120" height="32"/>
