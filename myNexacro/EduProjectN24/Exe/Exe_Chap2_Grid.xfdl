        <Static id="Static6_4" taborder="49" text="Edit 컴포넌트의 데이터를 바인딩 된 DataSet 에 즉시 반영시키기" left="80" top="594" width="520" height="30" onclick="Static08_onclick" positionstep="4"/>
        <Edit id="editInput" taborder="50" left="13" top="434" width="170" height="30" positionstep="4"/>
        <Radio id="Radio06" taborder="51" left="295" top="514" width="410" height="30" positionstep="4" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" columncount="-1" value="row" text="row" index="0" onitemchanged="Radio06_onitemchanged" rowcount="-1">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="codecolumn">row</Col>
                <Col id="datacolumn">row</Col>
              </Row>
              <Row>
                <Col id="codecolumn">multirow</Col>
                <Col id="datacolumn">multirow</Col>
              </Row>
              <Row>
                <Col id="codecolumn">cell</Col>
                <Col id="datacolumn">cell</Col>
              </Row>
              <Row>
                <Col id="codecolumn">area</Col>
                <Col id="datacolumn">area</Col>
              </Row>
              <Row>
                <Col id="codecolumn">multiarea</Col>
                <Col id="datacolumn">multiarea</Col>
