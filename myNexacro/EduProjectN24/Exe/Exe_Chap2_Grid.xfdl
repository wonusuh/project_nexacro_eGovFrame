        <Static id="Static10" taborder="29" text="Dataset2에 “COL_CHK” 컬럼을 추가하고 초기값을 “0”으로 지정.  &#13;&#10;Grid2의 맨 앞쪽에 빈 컬럼을 추가하고 생성한 Dataset컬럼(COL_CHK) 바인딩 " left="80" top="554" width="566" height="30"/>
        <Static id="Static11" taborder="30" text="해당 컬럼의 Head와 Body Cell을 “checkbox” 형태로 표현. " left="80" top="594" width="566" height="30"/>
        <Static id="Static12" taborder="31" text="컬럼 이동, 사이즈 변경 가능하게 속성 변경. " left="80" top="300" width="380" height="30" onclick="Static08_onclick" positionstep="1"/>
        <Static id="Static13" taborder="32" text="3번째 컬럼(Name)까지 고정, 3번째 Row까지 고정 " left="80" top="340" width="380" height="30" onclick="Static08_onclick" positionstep="1"/>
        <Static id="Static14" taborder="33" text="컬럼고정, Row고정 해제. " left="80" top="380" width="380" height="30" onclick="Static08_onclick" positionstep="1"/>
        <Static id="Static15" taborder="34" text="3번째 컬럼(Name) 사이즈 100px로 지정, 6번째 컬럼(Salary) 숨기기 " left="580" top="300" width="409" height="30" onclick="Static08_onclick" positionstep="1"/>
        <Static id="Static16" taborder="35" text="컬럼 숨기기 취소 " left="580" top="340" width="409" height="30" onclick="Static08_onclick" positionstep="1"/>
        <Static id="Static17" taborder="36" text="원본 그리드 포맷과 현재 변경한 그리드 포맷 비교. " left="580" top="380" width="409" height="30" onclick="Static08_onclick" positionstep="1"/>
        <Static id="Static18" taborder="37" text="법인(CORP), 부서(DEPT)별 소계 표현하기." left="80" top="524" width="380" height="30" onclick="Static08_onclick" positionstep="3"/>
