<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="App_Environment" width="1020" height="700" titletext="App_Environment">
    <Layouts>
      <Layout height="700" width="1020">
        <Static id="sta_title" taborder="0" text="Environment" left="20.00" top="0" width="300" height="60" cssclass="sta_WF_GuideTitle1"/>
