        <Grid id="grd_emp" taborder="5" left="10" top="134" right="10" bottom="334" onheadclick="grd_emp_onheadclick" autofittype="col" binddataset="ds_emp">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="48"/>
                <Column size="48"/>
                <Column size="48"/>
                <Column size="48"/>
                <Column size="48"/>
                <Column size="284"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="24" band="head"/>
                <Row size="24"/>
                <Row size="24" band="summ"/>
              </Rows>
              <Band id="head">
                <Cell text="함수"/>
                <Cell col="1" text="변수2"/>
                <Cell col="2" text="변수1"/>
                <Cell col="3" text="순번2"/>
                <Cell col="4" text="순번"/>
                <Cell col="5" text="사칙연산"/>
                <Cell col="6" text="이름"/>
                <Cell col="7" text="사번"/>
                <Cell col="8" text="부서코드"/>
                <Cell col="9" text="직위"/>
                <Cell col="10" text="고용일"/>
                <Cell col="11" text="급여"/>
                <Cell col="12" text="성별"/>
                <Cell col="13" text="결혼여부"/>
                <Cell col="14" text="스킬"/>
                <Cell col="15" text="취미"/>
                <Cell col="16" text="MEMO"/>
              </Band>
              <Band id="body">
                <Cell text="expr:comp.parent.fn_name(currow + 1)"/>
                <Cell col="1" text="expr:comp.parent.var2"/>
                <Cell col="2" text="expr:comp.parent.var1"/>
                <Cell col="3" text="expr:dataset.getRowCount() - currow" textAlign="center"/>
                <Cell col="4" text="expr:currow + 1" textAlign="center"/>
                <Cell col="5" text="expr:EMP_NAME +  EMP_ID"/>
                <Cell col="6" text="bind:EMP_NAME"/>
                <Cell col="7" text="bind:EMP_ID" edittype="mask" displaytype="mask" maskedittype="string" maskeditformat="AA-###"/>
                <Cell col="8" text="bind:DEPT_CODE" displaytype="combocontrol" edittype="combo" combodataset="ds_dept" combocodecol="DEPT_CODE" combodatacol="DEPT_NAME"/>
                <Cell col="9" text="bind:POSITION" displaytype="combotext" edittype="combo" combodataset="ds_pos" combocodecol="CODE" combodatacol="NAME"/>
                <Cell col="10" text="bind:HIRE_DATE"/>
                <Cell col="11" text="bind:SALARY"/>
                <Cell col="12" text="expr:GENDER == &quot;M&quot; ? &quot;남성&quot; : GENDER == &quot;F&quot; ? &quot;여성&quot; : &quot;기타&quot;"/>
                <Cell col="13" text="bind:MARRIED" displaytype="checkboxcontrol" edittype="checkbox"/>
                <Cell col="14" text="bind:SKILL" displaytype="multicombocontrol" edittype="multicombo" multicombodataset="ds_skill" multicombocodecol="CODE" multicombodatacol="NAME"/>
                <Cell col="15" text="bind:HOBBY" displaytype="multicombocontrol" edittype="multicombo" multicombodataset="ds_hobby" multicombocodecol="CODE" multicombodatacol="NAME"/>
                <Cell col="16" text="bind:MEMO"/>
              </Band>
              <Band id="summary">
                <Cell/>
                <Cell col="1"/>
                <Cell col="2"/>
                <Cell col="3" text="expr:comp.parent.ds_emp.getRowCount()"/>
                <Cell col="4" text="expr:dataset.getRowCount()"/>
                <Cell col="5"/>
                <Cell col="6"/>
                <Cell col="7"/>
                <Cell col="8"/>
                <Cell col="9"/>
                <Cell col="10"/>
                <Cell col="11" text="expr:dataset.getSum(&quot;SALARY&quot;)" displaytype="number"/>
                <Cell col="12"/>
                <Cell col="13"/>
                <Cell col="14"/>
                <Cell col="15"/>
                <Cell col="16"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
