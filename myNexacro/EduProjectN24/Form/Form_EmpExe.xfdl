    <Script type="xscript5.1"><![CDATA[let var1 = 'abc';
this.var2 = '가나다';

this.fn_name = (arg) => {
	return arg + 'pos';
};

// 조회
this.btn_retrieve_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.transaction(
		"strSelect", // 서비스 아이디
		"SvcUrl::select_emp.jsp", // 호출할 url
		"", // 저장 server ds = client ds
		"ds_emp=out_emp", // 조회 client ds = server ds
		"a=b c=" + nexacro.wrapQuote("a b"), // 전달값 (파라미터값)
		"fnCallback" // 콜백함수
	);
};

this.fnCallback = (sid, ecd, emsg) => {
	if(ecd >= 0) {
		if(sid === 'strSelect') {
			alert('조회 성공');
			return;
		} else if (sid === 'strSave') {
			alert('저장 성공');
			return;
		}
	} else {
		alert('실패');
		return;
	}
};

// 추가
this.btn_add_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.ds_emp.addRow();
	this.ds_emp.setColumn(this.ds_emp.rowposition, "HIRE_DATE", "20260529");
};

// 삭제
this.btn_delete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.ds_emp.deleteRow(this.ds_emp.rowposition);
};

// 저장
this.btn_save_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
		this.transaction(
			"strSave", // 서비스 아이디
			"SvcUrl::save_emp.jsp", // 호출할 url
			"in_emp=ds_emp:U", // 저장 server ds = client ds
			"", // 조회 client ds = server ds
			"a=b c=" + nexacro.wrapQuote("a b"), // 전달값 (파라미터값)
			"fnCallback" // 콜백함수
		);
};


// 화면이 로딩되면 공통코드를 호출
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
		this.transaction(
			"strCode", // 서비스 아이디
			"SvcUrl::select_code.jsp", // 호출할 url
			"", // 저장 server ds = client ds
			"ds_dept=out_dept ds_pos=out_pos ds_skill=out_skill ds_hobby=out_hobby", // 조회 client ds = server ds
			"a=b c=" + nexacro.wrapQuote("a b"), // 전달값 (파라미터값)
			"" // 콜백함수
		);
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="div_detail.form.edt_name" propid="value" datasetid="ds_emp" columnid="EMP_NAME"/>
      <BindItem id="item1" compid="div_detail.form.msk_empId" propid="value" datasetid="ds_emp" columnid="EMP_ID"/>
      <BindItem id="item2" compid="div_detail.form.Calendar00" propid="value" datasetid="ds_emp" columnid="HIRE_DATE"/>
      <BindItem id="item3" compid="div_detail.form.msk_salary" propid="value" datasetid="ds_emp" columnid="SALARY"/>
      <BindItem id="item4" compid="div_detail.form.txt_memo" propid="value" datasetid="ds_emp" columnid="MEMO"/>
      <BindItem id="item5" compid="div_detail.form.Combo00" propid="value" datasetid="ds_emp" columnid="DEPT_CODE"/>
      <BindItem id="item6" compid="div_detail.form.lsb_pos" propid="value" datasetid="ds_emp" columnid="POSITION"/>
      <BindItem id="item7" compid="div_detail.form.mcbo_hobby" propid="value" datasetid="ds_emp" columnid="HOBBY"/>
      <BindItem id="item8" compid="div_detail.form.CheckBoxSet00" propid="value" datasetid="ds_emp" columnid="SKILL"/>
      <BindItem id="item9" compid="div_detail.form.Radio00" propid="value" datasetid="ds_emp" columnid="GENDER"/>
      <BindItem id="item10" compid="div_detail.form.txt_memo" propid="background" datasetid="ds_emp" columnid="MEMO"/>
    </Bind>
  </Form>
</FDL>
