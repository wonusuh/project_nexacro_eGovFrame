  <Form id="Hello" width="1023" height="673" titletext="New Form" scrolltype="none">
    <Layouts>
      <Layout height="673" mobileorientation="landscape" width="1023">
        <Button id="btnHello" taborder="0" text="Hello World" left="80" top="30" width="120" height="50" background="darkblue" color="white" onclick="btnHello_onclick"/>
        <Button id="btnHello00" taborder="2" text="Hello World" left="80" top="97" width="120" height="50" background="darkblue" color="white" onclick="btnHello_onclick"/>
        <Button id="btnHello01" taborder="3" text="Hello World" left="80" top="164" width="120" height="50" background="darkblue" color="white" onclick="btnHello_onclick"/>
        <Static id="Static00" taborder="1" text="Desktop Screen" left="66" top="-133" width="240" height="30" font="normal bold 14px &quot;Arial&quot;" color="red"/>
