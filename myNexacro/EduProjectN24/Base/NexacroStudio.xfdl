include "Lib::Lib_Common.xjs"

this.btnHello_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.alert("Hello World");
	trace("log Hello World");
	if(e.altkey)
	{
		this.alert("true");	
	} else {
		this.alert("false");	
	}
};

