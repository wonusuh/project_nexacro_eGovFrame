              </Radio>
              <CheckBox id="chk_married" taborder="22" left="rdo_gender:-11" top="75" width="112" height="26" text="TEXT(&quot;married&quot;,&quot;결혼여부&quot;)" iconPosition="right" fittocontents="width"/>
              <CheckBoxSet id="chks_skill" taborder="23" left="Stati16:5" top="209" height="70" innerdataset="ds_skill" codecolumn="CODE" datacolumn="NAME" rowcount="3" right="38"/>
              <TextArea id="txt_memo" taborder="24" left="Stati20:5" top="110" height="90" right="129"/>
              <MultiCombo id="mcbo_hobby" taborder="25" text="MultiCombo00" left="Stati18:5" top="210" height="68" innerdataset="ds_hobby" codecolumn="CODE" datacolumn="NAME" buttonsize="28" width="30.907278165503488%" edittype="text"/>
            </Layout>
          </Layouts>
        </Div>
