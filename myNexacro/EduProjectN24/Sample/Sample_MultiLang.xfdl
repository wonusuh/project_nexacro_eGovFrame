<FDL version="2.1">
  <Form id="Form_Emp" width="1023" height="700" titletext="Employees" onload="form_onload" locale="en_US">
    <Layouts>
      <Layout height="700" width="1023" stepcount="0">
        <Static id="Static00" taborder="0" text="TEXT(&quot;employee.management&quot;,&quot;사원 관리&quot;)" left="10" top="0" width="88" height="50" cssclass="sta_WF_GuideTitle1"/>
        <Button id="btn_save" taborder="4" text="TEXT(&quot;action.save&quot;,&quot;저장&quot;)" top="12" width="50" height="26" cssclass="btn_WF_CRUD" right="10" onclick="btn_save_onclick"/>
        <Button id="btn_delete" taborder="3" text="TEXT(&quot;action.delete&quot;,&quot;삭제&quot;)" top="12" width="50" height="26" cssclass="btn_WF_CRUD" right="btn_save:5" onclick="btn_delete_onclick" fittocontents="width"/>
        <Button id="btn_add" taborder="2" text="TEXT(&quot;action.add&quot;,&quot;입력&quot;)" top="12" width="50" height="26" cssclass="btn_WF_CRUD" right="btn_delete:5" onclick="btn_add_onclick"/>
        <Button id="btn_retrieve" taborder="1" text="TEXT(&quot;action.retrieve&quot;,&quot;조회&quot;)" top="12" width="50" height="26" cssclass="btn_WF_CRUD" right="btn_add:5" onclick="btn_retrieve_onclick" fittocontents="width"/>
        <Div id="div_search" taborder="5" text="Div00" left="10.00" top="50" height="44" cssclass="div_WF_Search" formscrollbartype="none none" right="10" minwidth="1000" maxwidth="">
          <Layouts>
            <Layout>
              <Static id="Static00" taborder="0" text="TEXT(&quot;dept&quot;,&quot;부서&quot;)" left="0" top="9" width="74" height="26" cssclass="sta_WF_SchLabel" fittocontents="width"/>
              <Edit id="edt_deptCode" taborder="1" left="Static00:0" top="9" width="90" height="26" text=""/>
              <Button id="btn_findDept" taborder="2" left="Static00:60" top="8" width="28" height="28" cssclass="btn_WF_Find" onclick="div_search_btn_findDept_onclick"/>
              <Edit id="edt_deptName" taborder="3" left="Static00:88" top="9" width="170" height="26" readonly="true" text=""/>
              <Static id="Static01" taborder="6" text="TEXT(&quot;name&quot;,&quot;성명&quot;)" left="edt_deptName:0" top="9" width="74" height="26" cssclass="sta_WF_SchLabel" fittocontents="width"/>
              <Edit id="edt_empName" taborder="7" left="Static01:0" top="9" width="130" height="26"/>
              <Static id="Static02" taborder="4" text="TEXT(&quot;gender&quot;,&quot;성별&quot;)" left="edt_empName:0" top="9" width="74" height="26" cssclass="sta_WF_SchLabel" fittocontents="width"/>
              <Radio id="rdo_gender" taborder="5" left="Static02:0" top="9" width="220" height="26" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" rowcount="-1" columncount="-1" value="A" text="All" index="0" onitemchanged="div_search_rdo_gender_onitemchanged">
                <Dataset id="innerdataset">
                  <ColumnInfo>
                    <Column id="codecolumn" size="256"/>
                    <Column id="datacolumn" size="256"/>
                  </ColumnInfo>
                  <Rows>
                    <Row>
                      <Col id="codecolumn">A</Col>
                      <Col id="datacolumn">All</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">M</Col>
                      <Col id="datacolumn">Male</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">F</Col>
                      <Col id="datacolumn">Female</Col>
                    </Row>
                  </Rows>
                </Dataset>
              </Radio>
            </Layout>
          </Layouts>
        </Div>
        <Static id="Static01" taborder="8" text="TEXT(&quot;employee.list&quot;,&quot;사원 목록&quot;)" left="10" top="94" width="158" height="40" cssclass="sta_WF_GuideTitle2"/>
        <Grid id="grd_emp" taborder="6" left="10" top="134" right="10" binddataset="ds_emp" bottom="334" onheadclick="grd_emp_onheadclick" autofittype="col">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="48"/>
                <Column size="90"/>
                <Column size="80"/>
                <Column size="150"/>
                <Column size="150"/>
                <Column size="120"/>
                <Column size="80"/>
                <Column size="60"/>
                <Column size="70"/>
                <Column size="150"/>
              </Columns>
              <Rows>
                <Row size="30" band="head"/>
                <Row size="30"/>
                <Row size="24" band="summ"/>
              </Rows>
              <Band id="head">
                <Cell text="No"/>
                <Cell col="1" text="TEXT(&quot;name&quot;,&quot;성명&quot;)"/>
                <Cell col="2" text="TEXT(&quot;employee.id&quot;,&quot;사원번호&quot;)"/>
                <Cell col="3" text="TEXT(&quot;dept.name&quot;,&quot;부서명&quot;)"/>
                <Cell col="4" text="TEXT(&quot;employee.positoin&quot;,&quot;직급&quot;)"/>
                <Cell col="5" text="TEXT(&quot;employee.positoin&quot;,&quot;입사일자&quot;)"/>
                <Cell col="6" text="TEXT(&quot;salary&quot;,&quot;급여&quot;)"/>
                <Cell col="7" text="TEXT(&quot;gender&quot;,&quot;성별&quot;)"/>
                <Cell col="8" text="TEXT(&quot;married&quot;,&quot;결혼여부&quot;)"/>
                <Cell col="9" text="TEXT(&quot;skill&quot;,&quot;보유스킬&quot;)"/>
              </Band>
              <Band id="body">
                <Cell text="expr:currow + 1" displaytype="text"/>
                <Cell col="1" text="bind:EMP_NAME" edittype="normal"/>
                <Cell col="2" text="bind:EMP_ID" displaytype="mask" edittype="mask" maskedittype="string" maskeditformat="AA-###"/>
                <Cell col="3" text="bind:DEPT_CODE" displaytype="combotext" edittype="combo" combodataset="ds_dept" combocodecol="DEPT_CODE" combodatacol="DEPT_NAME"/>
                <Cell col="4" text="bind:POSITION" displaytype="combocontrol" edittype="combo" combodataset="ds_pos" combocodecol="CODE" combodatacol="NAME"/>
                <Cell col="5" text="bind:HIRE_DATE" displaytype="date" edittype="date"/>
                <Cell col="6" text="bind:SALARY" displaytype="mask" edittype="mask" maskeditformat="#,#"/>
                <Cell col="7" text="expr:GENDER == &quot;M&quot; ? &quot;Male&quot; : &quot;Female&quot;" displaytype="text"/>
                <Cell col="8" text="bind:MARRIED" displaytype="checkboxcontrol" edittype="checkbox"/>
                <Cell col="9" text="bind:SKILL" displaytype="multicombocontrol" edittype="multicombo" multicombodataset="ds_skill" multicombocodecol="CODE" multicombodatacol="NAME"/>
              </Band>
              <Band id="summary">
                <Cell/>
                <Cell col="1"/>
                <Cell col="2"/>
                <Cell col="3"/>
                <Cell col="4"/>
                <Cell col="5" text="expr:TEXT(&quot;salary&quot;,&quot;급여&quot;) + &quot; &quot; + TEXT(&quot;avg&quot;,&quot;평균&quot;)"/>
                <Cell col="6" text="expr:nexacro.round(dataset.getAvg(&quot;SALARY&quot;), 2)" displaytype="number" maskeditformat="#,#.00"/>
                <Cell col="7"/>
                <Cell col="8"/>
                <Cell col="9"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
