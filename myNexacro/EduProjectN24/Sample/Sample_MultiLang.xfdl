              <Combo id="cbo_dept" taborder="18" text="Combo00" left="Static04:5" top="40" width="180" height="26" innerdataset="ds_dept" codecolumn="DEPT_CODE" datacolumn="DEPT_NAME"/>
              <ListBox id="lsb_pos" taborder="19" left="Static06:5" top="110" width="180" height="90" innerdataset="ds_pos" codecolumn="CODE" datacolumn="NAME"/>
