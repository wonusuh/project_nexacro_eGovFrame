        <MaskEdit id="MaskEdit00" taborder="5" left="20" top="193" width="120" height="26" type="string" format="AA-###"/>
        <Static id="Static04" taborder="6" text="format = &quot;aa-@@@&quot;" left="160.00" top="167" width="112" height="26" cssclass="sta_WF_GuideRefer"/>
        <MaskEdit id="MaskEdit01" taborder="7" left="160.00" top="193" width="120" height="26" type="string" format="aa-@@@"/>
        <Static id="Static05" taborder="8" text="format = &quot;######-#{######}&quot;" left="300.00" top="167" width="178" height="26" cssclass="sta_WF_GuideRefer"/>
        <MaskEdit id="MaskEdit02" taborder="9" left="300.00" top="193" width="120" height="26" type="string" format="######-#{######}"/>
        <Grid id="Grid00" taborder="10" left="20" top="224" width="395" height="54" binddataset="ds_data" autofittype="col" useselcolor="false">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="26" band="head"/>
                <Row size="26"/>
              </Rows>
              <Band id="head">
                <Cell text="string1"/>
                <Cell col="1" text="string2"/>
                <Cell col="2" text="string3"/>
              </Band>
              <Band id="body">
                <Cell text="bind:STR1"/>
                <Cell col="1" text="bind:STR2"/>
                <Cell col="2" text="bind:STR3"/>
