        <Radio id="Radio00" taborder="9" left="36.00" top="370" width="248" height="26" codecolumn="codecolumn" datacolumn="datacolumn" columncount="-1" value="none" onitemchanged="Radio00_onitemchanged" rowcount="-1" innerdataset="innerdataset" index="0">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="codecolumn">none</Col>
                <Col id="datacolumn">none</Col>
              </Row>
              <Row>
                <Col id="codecolumn">fit</Col>
                <Col id="datacolumn">fit</Col>
              </Row>
              <Row>
                <Col id="codecolumn">fixaspectratio</Col>
                <Col id="datacolumn">fixaspectratio</Col>
              </Row>
            </Rows>
          </Dataset>
        </Radio>
        <ImageViewer id="ImageViewer02" taborder="10" left="624" top="157" width="250" height="79" image="url('https://www.tobesoft.com/assets/images/sub/bg/logoType_tobesoft_mo.png')" stretch="fixaspectratio"/>
        <Static id="Static06" taborder="11" text="imege = &quot;https://www.tobesoft.com/...&quot;" left="624" top="131" width="251" height="26" cssclass="sta_WF_GuideRefer"/>
