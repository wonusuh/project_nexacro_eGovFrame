          <Formats>
            <Format id="default">
              <Columns>
                <Column size="42"/>
                <Column size="126"/>
                <Column size="136"/>
                <Column size="147"/>
                <Column size="73"/>
                <Column size="100"/>
              </Columns>
              <Rows>
                <Row size="30" band="head"/>
                <Row size="30"/>
              </Rows>
              <Band id="head">
                <Cell text="No"/>
                <Cell col="1" text="Name"/>
                <Cell col="2" text="Hire Date"/>
                <Cell col="3" text="Annual Salary"/>
                <Cell col="4" text="Married"/>
                <Cell col="5"/>
              </Band>
              <Band id="body">
                <Cell text="expr:currow + 1" displaytype="text"/>
                <Cell col="1" text="bind:EMP_NAME" textAlign="center"/>
                <Cell col="2" text="bind:HIRE_DATE" textAlign="center" edittype="date"/>
                <Cell col="3" text="bind:SALARY" textAlign="right"/>
                <Cell col="4" displaytype="checkboxcontrol" edittype="checkbox" text="bind:MARRIED"/>
                <Cell col="5" text="bind:IMG_URL" displaytype="imagecontrol"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
