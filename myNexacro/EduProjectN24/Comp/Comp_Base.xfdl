    <Script type="xscript5.1"><![CDATA[
this.btn_exe_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.ProgressBar00.pos = 0;
	this.setTimer(0,10);
};

this.btn_popMenu_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var nX = parseInt(obj.width);	
	var nY = 0;
	this.PopupMenu00.trackPopupByComponent(obj, nX, nY);	
};

this.btn_popDiv_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var nX = parseInt(obj.width);	
	var nY = 0;
	this.PopupDiv00.trackPopupByComponent(obj, nX, nY, 270, 90);	
};


this.Comp_Base_ontimer = function(obj:nexacro.Form,e:nexacro.TimerEventInfo)
{
	if(e.timerid == 0 ){
		if(this.ProgressBar00.pos == 100){
			this.killTimer(0);
		}
		this.ProgressBar00.stepIt();
	}
	
};

this.btn_openDateRange_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.PopupDateRangePicker00.trackPopupByComponent("start", obj, 0, obj.height);
};
]]></Script>
  </Form>
</FDL>
