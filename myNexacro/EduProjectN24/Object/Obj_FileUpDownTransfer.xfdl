<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Obj_FileUpDownTransfer" left="0" top="0" width="1020" height="700" titletext="Obj_FileUpDownTransfer" border="" background="">
    <Layouts>
      <Layout height="700" width="1020" stepcount="0" screenid="desktop,Desktop_screen">
        <Static id="Static02" taborder="0" text="FileDownload" cssclass="sta_WF_GuideTitle2" left="20" top="380" width="250" height="35" positionstep="0"/>
        <Button id="btnDel" taborder="1" text="delete" top="64" width="69" height="26" onclick="btnDel_onclick" positionstep="0" right="93" cssclass="btn_WF_LineBlue"/>
        <Grid id="grdFileUpload" taborder="2" left="20" top="95" height="260" binddataset="dsUpload" autofittype="col" nodatatext="You can attach files by dragging them." positionstep="0" right="20" oncelldblclick="grdFileUpload_oncelldblclick" ondrop="grdFileUpload_ondrop" onheadclick="grdFileUpload_onheadclick">
