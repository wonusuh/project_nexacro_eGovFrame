          </Formats>
        </Grid>
        <Button id="btnUpload" taborder="3" text="upload" top="64" width="69" height="26" onclick="btnUpload_onclick" positionstep="0" right="20" cssclass="btn_WF_LineBlue"/>
        <Grid id="grdFileDownload" taborder="4" left="20" binddataset="dsDownload" autofittype="col" positionstep="0" right="20" oncelldblclick="grdFileDownload_oncelldblclick" onheadclick="grdFileDownload_onheadclick" top="415" height="260">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="35" band="left"/>
                <Column size="152"/>
                <Column size="320"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="30" band="head"/>
                <Row size="30"/>
